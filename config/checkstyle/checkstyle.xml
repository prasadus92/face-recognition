<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
  "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
  "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Pragmatic Checkstyle baseline.

  Philosophy: only include rules whose violations would likely indicate a
  real bug or maintainability trap. Cosmetic brace-position checks are
  deliberately omitted because this codebase (like most idiomatic Java)
  uses single-line getters/setters on DTOs and K&R braces elsewhere,
  and mechanical reformatting buys nothing but noise.

  Reference: https://checkstyle.org/checks.html
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="warning"/>
    <property name="fileExtensions" value="java,properties,xml"/>

    <module name="SuppressionFilter">
        <property name="file" value="config/checkstyle/suppressions.xml"/>
        <property name="optional" value="true"/>
    </module>

    <!-- File-level -->
    <module name="FileTabCharacter">
        <property name="severity" value="error"/>
    </module>
    <module name="NewlineAtEndOfFile">
        <property name="lineSeparator" value="lf_cr_crlf"/>
    </module>
    <module name="LineLength">
        <property name="max" value="160"/>
        <property name="ignorePattern" value="^(package|import) .*$|.*https?://.*$"/>
    </module>

    <module name="TreeWalker">
        <property name="tabWidth" value="4"/>

        <!-- Imports: unused/star/redundant imports almost always indicate dead code. -->
        <module name="AvoidStarImport">
            <property name="excludes" value="java.util,java.io,java.awt,org.mockito.Mockito,org.assertj.core.api.Assertions"/>
        </module>
        <module name="UnusedImports">
            <property name="processJavadoc" value="true"/>
        </module>
        <module name="RedundantImport"/>

        <!-- Coding checks that catch real bugs — these fail the build. -->
        <module name="FallThrough">
            <property name="severity" value="error"/>
        </module>
        <module name="EqualsHashCode">
            <property name="severity" value="error"/>
        </module>
        <module name="StringLiteralEquality">
            <property name="severity" value="error"/>
        </module>
        <module name="EmptyStatement">
            <property name="severity" value="error"/>
        </module>
        <module name="MissingSwitchDefault"/>
        <module name="SimplifyBooleanExpression"/>
        <module name="SimplifyBooleanReturn"/>
        <module name="ModifierOrder"/>
        <module name="OneStatementPerLine"/>

        <!-- Naming: trivially enforceable and catches typos / shouting. -->
        <module name="TypeName"/>
        <module name="MemberName"/>
        <module name="LocalVariableName"/>
        <module name="ConstantName"/>
        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9_$]*$"/>
        </module>
    </module>
</module>
